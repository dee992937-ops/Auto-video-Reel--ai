rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Project Hardening
    function isValidProject(data) {
      return data.keys().hasAll(['name', 'formData', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() <= 100
        && data.formData is map
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().userId) && isValidId(projectId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isValidProject(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isOwner(existing().userId)
        && isValidId(projectId)
        && isValidProject(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'formData', 'updatedAt']);

      allow delete: if isOwner(existing().userId);
    }

    // 2. UserTemplate Hardening
    function isValidTemplate(data) {
      return data.keys().hasAll(['name', 'config', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() <= 100
        && data.config is map
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /userTemplates/{templateId} {
      allow get: if isOwner(existing().userId) && isValidId(templateId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && isValidId(templateId)
        && isValidTemplate(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isOwner(existing().userId)
        && isValidId(templateId)
        && isValidTemplate(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'config', 'updatedAt']);

      allow delete: if isOwner(existing().userId);
    }
  }
}
